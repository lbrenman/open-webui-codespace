# ============================================
# Open WebUI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# --- OpenAI ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Anthropic (via LiteLLM proxy) ---
# Open WebUI doesn't natively support Anthropic directly.
# Use a LiteLLM proxy and point OPENAI_API_BASE_URL at it.
# OR use the community Open WebUI Anthropic pipe (see README).
ANTHROPIC_API_KEY=

# --- External OpenAI Compatible API ---
# If you're running an external OpenAI compatible API, set the base URL here.
# This lets Open WebUI talk to Claude, Grok, Gemini, etc. or whateer your API exposes
# via a single OpenAI-compatible endpoint.
# OPENAI_API_BASE_URL=http://host.docker.internal:4000
# OPENAI_API_KEY=your-bearer-token

# --- Ollama (only used by start-with-ollama.sh) ---
# Default model to pull when starting with Ollama
OLLAMA_DEFAULT_MODEL=phi3:mini
